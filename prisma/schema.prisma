generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model RequestLog {
  id           String   @id @default(cuid())
  method       String
  url          String
  statusCode   Int
  requestBody  Json?
  responseBody Json?
  headers      Json?
  ip           String?
  userAgent    String?
  duration     Int
  createdAt    DateTime @default(now())

  @@map("request_logs")
}
